# PostgreSQL (remoto - CulturaEduca)
PG_HOST=
PG_PORT=5432
PG_DATABASE=
PG_USER=
PG_PASSWORD=

# Neo4j (local)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Salvar CSVs intermediários para conferência (true/false)
SALVAR_CSV=true

# Escopo territorial da carga:
#   cidades -> apenas os 3 municípios (São Paulo, São Bernardo, Campinas)
#   estado  -> todos os municípios da UF definida abaixo
ESCOPO=cidades
UF=35
